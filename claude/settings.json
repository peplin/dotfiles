{
  "fileSuggestion": {
    "type": "command",
    "command": "~/.dotfiles/claude/file-suggestion.sh"
  },
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(chmod *)",
      "Bash(find *)",
      "Bash(git:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "~/dev",
      "~/.dotfiles"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/claude/statusline.sh",
    "padding": 0
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "."
      ],
      "denyWrite": [
        "/"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        "."
      ]
    },
    "writePaths": [
      "/home/cpeplin/.cache/bazel",
      "/data/home/cpeplin/.cache/bazel",
      "/tmp"
    ]
  },
  "alwaysThinkingEnabled": false,
  "autoUpdatesChannel": "latest",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  }
}
