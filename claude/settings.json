{
  "fileSuggestion": {
    "type": "command",
    "command": "~/.dotfiles/claude/file-suggestion.sh"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(chmod *)",
      "Bash(find *)"
    ],
    "additionalDirectories": [
      "~/dev",
      "~/.dotfiles"
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/claude/statusline.sh",
    "padding": 0
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "writePaths": [
      "/home/cpeplin/.cache/bazel",
      "/data/home/cpeplin/.cache/bazel",
      "/tmp"
    ]
  },
  "alwaysThinkingEnabled": false,
  "autoUpdatesChannel": "latest"
}
